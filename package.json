{
  "name": "tailwind-starter",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tailwindcss -i ./src/css/main.css -o ./dist/output.css --watch",
    "build": "tailwindcss -i ./src/css/main.css -o ./dist/output.css --minify",
    "start": "npm run dev"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  }
}